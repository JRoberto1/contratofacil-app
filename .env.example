# =============================================================================
# ContratoFácil — Variáveis de Ambiente
# © 2026 FlowIQ. Todos os direitos reservados.
#
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local — ele está no .gitignore.
# NUNCA use variáveis sem NEXT_PUBLIC_ em componentes client-side.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# -----------------------------------------------------------------------------
# xAI Grok — https://console.x.ai
# Modelo: grok-4-fast | ~R$ 0,003 por contrato gerado
# NUNCA exponha esta chave no browser — use apenas em API Routes
# -----------------------------------------------------------------------------
GROK_API_KEY=xai-...

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com/apikeys
# Pagamentos via cartão (planos Mensal, Semestral, Anual)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# AbacatePay — https://abacatepay.com
# Pagamentos via Pix (plano Avulso R$ 4,90)
# -----------------------------------------------------------------------------
ABACATEPAY_API_KEY=abacate_...

# -----------------------------------------------------------------------------
# Preços (em centavos)
# -----------------------------------------------------------------------------
PRECO_AVULSO_CENTAVOS=490
PRECO_MENSAL_CENTAVOS=1900
PRECO_SEMESTRAL_CENTAVOS=8900
PRECO_ANUAL_CENTAVOS=15900

# -----------------------------------------------------------------------------
# Resend — https://resend.com
# E-mails transacionais (confirmação de pagamento, entrega do PDF)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@contratofacil.com.br

# -----------------------------------------------------------------------------
# Google Analytics 4
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
